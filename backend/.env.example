# Motech Platform Backend — environment configuration
# انسخ هذا الملف إلى .env وعدّل القيم

# PostgreSQL — standard connection string only (portable: Supabase/VPS = غيّر هذا فقط)
DATABASE_URL=postgres://motech:motech_dev_2026@127.0.0.1:5432/motech_platform?sslmode=disable

# NetBird API — switchable: Cloud now, Self-Hosted later (غيّر URL فقط)
NETBIRD_API_URL=https://api.netbird.io
NETBIRD_API_TOKEN=

# Auth
JWT_SECRET=change-me-to-a-long-random-secret-in-production

# Master key for AES-256-GCM encryption of stored private keys (32 bytes, base64 or hex)
MASTER_KEY=change-me-32-byte-key-for-aes-256-gcm!!

# Server
PORT=8080

# First admin seeded on startup if no admin exists
SEED_ADMIN_EMAIL=admin@motech.local
SEED_ADMIN_PASSWORD=admin123
